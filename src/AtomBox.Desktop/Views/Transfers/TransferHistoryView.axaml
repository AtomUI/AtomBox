<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:pages="using:AtomBox.Desktop.ViewModels.Pages"
             x:Class="AtomBox.Desktop.Views.Transfers.TransferHistoryView"
             x:DataType="pages:TransferHistoryViewModel">
    <UserControl.Styles>
        <Style Selector="Border.transfer-row:pointerover">
            <Setter Property="Background" Value="{StaticResource AtomBoxRowHoverBrush}" />
        </Style>
        <Style Selector="Border.transfer-row:pointerover Grid.transfer-row-content">
            <Setter Property="Background" Value="{StaticResource AtomBoxRowHoverBrush}" />
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="56,*,48">
        <Border Grid.Row="0"
                Classes="app-page-header">
            <DockPanel LastChildFill="False"
                       VerticalAlignment="Center">
                <TextBlock DockPanel.Dock="Left"
                           Classes="app-page-title"
                           Text="{Binding Title}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>
        <Grid Grid.Row="1"
              Classes="app-page-content"
              RowDefinitions="*">
            <atom:ScopeAwareOverlayLayerPanel Grid.Row="0"
                                              ClipToBounds="False">
                <Border Classes="app-list-surface">
                    <Grid RowDefinitions="40,*">
                        <Grid Grid.Row="0"
                              ColumnDefinitions="1.4*,90,2*,90,150"
                              Classes="app-list-header">
                            <TextBlock Grid.Column="0" Text="文件名" Margin="12,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="方向" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="目标 / 来源" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="结果" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="完成时间" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </Grid>
                        <Grid Grid.Row="1">
                            <ScrollViewer IsVisible="{Binding IsTaskListVisible}">
                                <ItemsControl ItemsSource="{Binding Tasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="pages:TransferHistoryRowViewModel">
                                            <Border Classes="transfer-row"
                                                    MinHeight="40"
                                                    BorderBrush="{StaticResource AtomBoxSubtleBorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Background="{StaticResource AtomBoxSurfaceBrush}"
                                                    PointerEntered="HandleTransferRowPointerEntered"
                                                    PointerMoved="HandleTransferRowPointerMoved"
                                                    PointerExited="HandleTransferRowPointerExited">
                                                <Grid Classes="transfer-row-content"
                                                      ColumnDefinitions="1.4*,90,2*,90,150"
                                                      Background="Transparent">
                                                    <TextBlock Grid.Column="0" Text="{Binding FileName}" Margin="12,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Direction}" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding TargetOrSource}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               PointerEntered="HandlePathPointerEntered"
                                                               PointerMoved="HandlePathPointerMoved"
                                                               PointerExited="HandlePathPointerExited" />
                                                    <atom:Tag Grid.Column="3"
                                                              Text="{Binding Result}"
                                                              TagColor="{Binding ResultTagColor}"
                                                              HorizontalAlignment="Left"
                                                              VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="4" Text="{Binding CompletedAt}" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <atom:Empty PresetImage="Simple"
                                        SizeType="Middle"
                                        Description="暂无历史记录。完成、失败、取消或中断的传输任务会显示在这里。"
                                        IsVisible="{Binding IsEmptyStateVisible}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Border>
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,20"
                        Padding="4"
                        Background="Transparent">
                    <Border Classes="app-float-action-frame">
                        <atom:FloatButton Classes="app-float-action"
                                          BoxShadow="0 0 0 0 Transparent"
                                          Icon="{antdicons:AntDesignIconProvider DeleteOutlined}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Command="{Binding ClearHistoryCommand}" />
                    </Border>
                </Border>
            </atom:ScopeAwareOverlayLayerPanel>
        </Grid>
        <DockPanel Grid.Row="2"
                   VerticalAlignment="Center"
                   Margin="20,0"
                   LastChildFill="False">
            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}"
                           Classes="app-muted-text"
                           VerticalAlignment="Center" />
                <atom:Button Content="查看详情"
                             Icon="{antdicons:AntDesignIconProvider InfoCircleOutlined}"
                             Command="{Binding ShowErrorDetailsCommand}"
                             IsVisible="{Binding HasErrorDetails}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        Spacing="8">
                <TextBlock Text="{Binding PageIndex, StringFormat='当前页 {0}'}"
                           Classes="app-muted-text"
                           VerticalAlignment="Center" />
                <atom:Button Content="上一页"
                             Icon="{antdicons:AntDesignIconProvider LeftOutlined}"
                             Command="{Binding PreviousPageCommand}" />
                <atom:Button Content="下一页"
                             Icon="{antdicons:AntDesignIconProvider RightOutlined}"
                             Command="{Binding NextPageCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
